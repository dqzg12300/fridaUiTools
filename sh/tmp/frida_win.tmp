@echo off
%adbPrefix% shell "killall %fName% %fridaName% frida-server" 2>nul
%adbPrefix% shell su -c "killall %fName% %fridaName% frida-server" 2>nul
%adbPrefix% shell su 0 sh -c "killall %fName% %fridaName% frida-server" 2>nul
%removeForwards%
timeout /t 1 >nul

%defaultForwards%
%customPort%
%adbPrefix% shell sh -c "chmod 0777 /data/local/tmp/%fName% 2>/dev/null & chmod 0777 /data/local/tmp/%fridaName% 2>/dev/null" || %adbPrefix% shell su -c "chmod 0777 /data/local/tmp/%fName% 2>/dev/null & chmod 0777 /data/local/tmp/%fridaName% 2>/dev/null" || %adbPrefix% shell su 0 sh -c "chmod 0777 /data/local/tmp/%fName% 2>/dev/null & chmod 0777 /data/local/tmp/%fridaName% 2>/dev/null"
%adbPrefix% shell sh -c "/data/local/tmp/%fridaLaunch%" || %adbPrefix% shell su -c "/data/local/tmp/%fridaLaunch%" 2>nul || %adbPrefix% shell su 0 sh -c "/data/local/tmp/%fridaLaunch%" 2>nul
